apiVersion: v1
kind: Pod
metadata:
  name: fail-unsigned
  namespace: kyverno-demo
  labels:
    team: demo
spec:
  securityContext:
    runAsNonRoot: true
  containers:
  - name: app
    image: d4vlin/firewall-service:${UNSIGNED_TAG}
    command: ["sh","-c","sleep 5"]
    resources:
      requests:
        cpu: "10m"
        memory: "64Mi"
      limits:
        cpu: "100m"
        memory: "128Mi"
